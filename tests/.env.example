# Local credentials for live integration tests. Copy to ``.env`` (which is
# gitignored) and fill in real values. CI passes these as real env vars.
#
# Live tests skip if no key is set; nothing else depends on these.

# OpenAI (default LLM provider)
# OPENAI_API_KEY=sk-...

# OpenAI-compatible endpoint (Ollama, LM Studio, OpenRouter, vLLM, ...)
# OPENAI_BASE_URL=https://openrouter.ai/api/v1
# OPENAI_MODEL=openai/gpt-4o-mini

# OpenRouter convenience: if only OPENROUTER_API_KEY is set, the test
# loader auto-points OPENAI_BASE_URL at OpenRouter and uses
# openai/gpt-4o-mini.
# OPENROUTER_API_KEY=sk-or-...

# LayerLens API key (the live test mocks the Stratix client, so this is
# only needed when running the *sample* end-to-end against real LayerLens).
# LAYERLENS_STRATIX_API_KEY=...
